#
# Copy this file to deploy/dreamhost.env and fill in your DreamHost
# deployment and production database details.
#

DREAMHOST_HOST=example.dreamhost.com
DREAMHOST_USERNAME=your_username
DREAMHOST_PASSWORD=your_password
DREAMHOST_REMOTE_PATH=/home/your_username/example.com
DREAMHOST_PORT=22

PROD_DB_HOST=127.0.0.1
PROD_DB_NAME=stock_report
PROD_DB_USER=your_prod_db_user
PROD_DB_PASSWORD=your_prod_db_password
PROD_DB_CHARSET=utf8mb4
PROD_SESSION_FILES_DIR=/home/your_username/example.com/storage/stock-reports
